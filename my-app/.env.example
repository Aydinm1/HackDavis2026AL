DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DATABASE?sslmode=verify-full&schema=public"

# Neon direct (non-pooled) URL — required for prisma migrate
# Same as DATABASE_URL but without "-pooler" in the hostname
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DATABASE?sslmode=verify-full&schema=public"

# Google Calendar OAuth (user login + calendar sync)
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"
GOOGLE_CALENDAR_SCOPES="https://www.googleapis.com/auth/calendar.readonly"

# Generate with: openssl rand -base64 32
GOOGLE_TOKEN_ENCRYPTION_KEY="your-random-token-encryption-key"

# Vertex AI / Gemini (powers the AI agent — NOT the same as user OAuth above)
# Get the service account JSON from a teammate and place it at the project root.
# The service account needs "Vertex AI User" role on the GCP project.
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS="./HackDavis_2026_Service_Account.json"
